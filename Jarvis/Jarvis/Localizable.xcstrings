{
  "sourceLanguage": "ru",
  "strings": {
    "": {},
    "(%lld)": {},
    "%@": {
      "comment": "A header row in the month calendar popup, showing the month and year.",
      "isCommentAutoGenerated": true
    },
    "%@ – %@": {
      "comment": "A pair of text elements that together display the start and end times of a sleep session. The first element shows the start time, and the second element shows the end time.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ – %2$@"
          }
        }
      }
    },
    "%@ (%lld)": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ (%2$lld)"
          }
        }
      }
    },
    "%@ %@": {
      "comment": "Кнопка, которая помечает задачу как выполненную или нет.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ %2$@"
          }
        }
      }
    },
    "%@ %lld": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ %2$lld"
          }
        }
      }
    },
    "%@ • %@": {
      "comment": "A text that shows the number of sleep cycles and their duration. The first argument is the string “%1$arg %2$arg”. The second argument is the string “%arg ч” or the string “%1$arg ч %2$arg мин”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ • %2$@"
          }
        }
      }
    },
    "%@, %@": {
      "comment": "A label that combines the task title and the time it is scheduled for, for accessibility. The argument is the string “%1$arg%2$arg” or the string “%1$arg:%2$arg%3$arg”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@, %2$@"
          }
        }
      }
    },
    "%@, %@, %@%@": {
      "comment": "A task with a title, start time, and duration. The task is marked as completed if specified. The argument is the string “%arg ч” or the string “%arg мин”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@, %2$@, %3$@%4$@"
          }
        }
      }
    },
    "%@, %@!": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@, %2$@!"
          }
        }
      }
    },
    "%@, %lld задач": {
      "comment": "A button representing a day in the calendar, with an optional badge indicating the number of tasks scheduled for that day. The first argument is the abbreviated weekday name. The second argument is the day number. The third argument is the count of tasks scheduled for that day.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@, %2$lld задач"
          }
        }
      }
    },
    "%@: %@": {
      "comment": "Кнопка добавления задачи.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@: %2$@"
          }
        }
      }
    },
    "%@: %@%@": {
      "comment": "A label that combines the title and value of the card, optionally including a subtitle. The argument is the string “%arg” or the string “%.1f”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@: %2$@%3$@"
          }
        }
      }
    },
    "%@: %lld": {
      "comment": "A mini card displaying a value and a label. The first argument is the string “Всего” or the string “%”. The second argument is the label.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@: %2$lld"
          }
        }
      }
    },
    "%@: %lld %@. %@": {
      "comment": "A heading that announces the productivity streak section of the view. The argument is the string “Начни серию — выполни хотя бы одну задачу сегодня!”, the string “Хорошее начало! Продолжай.”, the string “Отличная неделя! Так держать.”, the string “Впечатляющая серия!”, the string “Потрясающая продуктивность!” or the string “Ты — машина! 🔥”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@: %2$lld %3$@. %4$@"
          }
        }
      }
    },
    "%@%@": {
      "comment": "A label that describes the navigation row, optionally including the count of items in parentheses.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@%2$@"
          }
        }
      }
    },
    "%lld": {
      "comment": "A day number displayed in a calendar view.",
      "isCommentAutoGenerated": true
    },
