      "comment": "A label displaying the number of calories consumed on the current day. The argument is the number of calories consumed on the current day.",
      "isCommentAutoGenerated": true
    },
    "%lld min": {
      "comment": "A label displaying the total number of minutes spent on physical activity today.",
      "isCommentAutoGenerated": true
    },
    "%lld мин": {
