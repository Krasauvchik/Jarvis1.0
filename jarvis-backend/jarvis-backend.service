[Unit]
Description=Jarvis Backend API (HTTPS)
After=network.target

[Service]
Type=simple
User=bilal
WorkingDirectory=/home/bilal/jarvis-backend
ExecStartPre=/bin/bash /home/bilal/jarvis-backend/generate_certs.sh
ExecStart=/home/bilal/jarvis-backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --ssl-keyfile certs/server.key --ssl-certfile certs/server.crt
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
